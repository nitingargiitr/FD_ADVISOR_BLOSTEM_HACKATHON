# Copy this file to .env in the same folder (backend/) and fill in your key.
# Get a key at https://console.groq.com

GROQ_API_KEY=your_groq_api_key_here

# Optional: model id from Groq (default below if unset)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: comma-separated origins for CORS (default: http://localhost:5173)
# CORS_ORIGINS=http://localhost:5173
